@using Microsoft.AspNetCore.Components.Web

<style>
    .pager-nav .page-link {
        color: #6f42c1;
        background-color: transparent;
        border: none !important;
        font-size: 1.1rem;
        padding: 0.25rem 0.5rem;
    }
    .pager-nav .page-link:hover {
        background-color: #6f42c1;
        color: white;
        border-radius: 0.25rem;
    }
    .pager-nav .page-item.disabled .page-link {
        color: #adb5bd;
        pointer-events: none;
        background-color: transparent;
    }
    .pager-nav .page-item .page-link.text-white {
        color: white;
    }
    .pager-nav .page-current {
        display: inline-block;
        padding: 0.25rem 0.6rem;
        background-color: #6f42c1;
        color: white;
        border-radius: 0.25rem;
        font-weight: bold;
    }
</style>

@code {
    [Parameter] public int CurrentPage { get; set; }
    [Parameter] public int PageSize { get; set; }
    [Parameter] public int TotalItems { get; set; }
    [Parameter] public EventCallback<int> CurrentPageChanged { get; set; }
    [Parameter] public EventCallback<int> PageSizeChanged { get; set; }
    [Parameter] public EventCallback<int> OnPageChanged { get; set; }

    private int TotalPages => PageSize > 0 ? (int)Math.Ceiling(TotalItems / (double)PageSize) : 0;

    private async Task GoToPage(int page)
    {
        page = Math.Max(1, Math.Min(page, TotalPages));
        await CurrentPageChanged.InvokeAsync(page);
        await OnPageChanged.InvokeAsync(page);
    }
}

<nav aria-label="Page navigation" class="pager-nav">
    <ul class="pagination pagination-sm justify-content-center align-items-center">
        <li class="page-item @(CurrentPage <= 1 ? "disabled" : "")">
            <button class="page-link" @onclick="() => GoToPage(1)" disabled="@(CurrentPage <= 1)" title="В начало">
                <i class="bi bi-chevron-double-left"></i>
            </button>
        </li>
        <li class="page-item @(CurrentPage <= 1 ? "disabled" : "")">
            <button class="page-link" @onclick="() => GoToPage(CurrentPage - 1)" disabled="@(CurrentPage <= 1)" title="Предыдущая">
                <i class="bi bi-chevron-left"></i>
            </button>
        </li>
        <li class="page-item">
            <span class="page-current">@CurrentPage / @TotalPages</span>
        </li>
        <li class="page-item @(CurrentPage >= TotalPages ? "disabled" : "")">
            <button class="page-link" @onclick="() => GoToPage(CurrentPage + 1)" disabled="@(CurrentPage >= TotalPages)" title="Следующая">
                <i class="bi bi-chevron-right"></i>
            </button>
        </li>
        <li class="page-item @(CurrentPage >= TotalPages ? "disabled" : "")">
            <button class="page-link" @onclick="() => GoToPage(TotalPages)" disabled="@(CurrentPage >= TotalPages)" title="В конец">
                <i class="bi bi-chevron-double-right"></i>
            </button>
        </li>
    </ul>
</nav>