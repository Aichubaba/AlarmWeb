@page "/nodes"
@rendermode InteractiveServer
@using BlazorApp2.Models
@using BlazorApp2.Data
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@inject AppDbContext Db
@attribute [Authorize]

<style>
    .btn-purple {
        background-color: #6f42c1;
        border-color: #6f42c1;
        color: white;
    }
    .btn-purple:hover {
        background-color: #5a32a3;
        border-color: #5a32a3;
    }
    .sticky-header thead th {
        position: sticky;
        top: 0;
        background-color: #f1f3f5;
        color: #495057;
        z-index: 10;
        box-shadow: 0 2px 2px -1px rgba(0,0,0,0.1);
        border-bottom: 2px solid #dee2e6;
    }
</style>

<PageTitle>Узлы</PageTitle>

<div class="container-fluid">
    <h3 class="mb-4">Список Node</h3>

    <div class="d-flex flex-wrap align-items-center gap-2 mb-3">
        <input type="text" class="form-control" style="width:240px;" placeholder="Поиск по названию..." @bind="searchTitle" @onkeydown="OnSearchKeyDown" />
        <button class="btn btn-purple" @onclick="FilterData"><i class="bi bi-search me-1"></i> Найти</button>
        <button class="btn btn-outline-secondary" @onclick="ResetFilters"><i class="bi bi-arrow-counterclockwise me-1"></i> Сбросить</button>
    </div>

    @if (nodesList == null)
    {
        <div class="text-center">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Загрузка...</span>
            </div>
        </div>
    }
    else
    {
        <div class="table-responsive" style="max-height: 70vh; overflow-y: auto;">
            <table class="table table-hover sticky-header">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Группа</th>
                        <th>ПВН</th>
                        <th>Название</th>
                        <th>Локация</th>
                        <th>Модель</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in pagedList)
                    {
                        <tr>
                            <td>@item.Id</td>
                            <td>@item.Group</td>
                            <td>@item.PvnNumber</td>
                            <td>@item.Title</td>
                            <td>@item.Location</td>
                            <td>@item.ModelName</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="d-flex justify-content-center mt-3">
            <Pager @bind-CurrentPage="currentPage" @bind-PageSize="pageSize" TotalItems="@(nodesList?.Count ?? 0)" OnPageChanged="OnPageChanged" />
        </div>
    }
</div>

@code {
    private List<Node>? nodesList;
    private List<Node> pagedList = new();
    private string searchTitle = "";
    private int currentPage = 1;
    private int pageSize = 20;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        var query = Db.Nodes.AsQueryable();

        if (!string.IsNullOrWhiteSpace(searchTitle))
        {
            query = query.Where(n => n.Title != null && n.Title.Contains(searchTitle));
        }

        nodesList = await query.ToListAsync();
        UpdatePagedList();
    }

    private void UpdatePagedList()
    {
        if (nodesList == null)
        {
            pagedList = new List<Node>();
            return;
        }
        pagedList = nodesList
            .Skip((currentPage - 1) * pageSize)
            .Take(pageSize)
            .ToList();
    }

    private async Task FilterData()
    {
        currentPage = 1;
        await LoadData();
    }

    private void ResetFilters()
    {
        searchTitle = "";
        currentPage = 1;
        LoadData();
    }

    private void OnPageChanged(int page)
    {
        currentPage = page;
        UpdatePagedList();
    }

    private void OnSearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") FilterData();
    }
}