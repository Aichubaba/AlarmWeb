@page "/"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using BlazorApp2.Data
@using BlazorApp2.Models
@using BlazorApp2.Services
@inject AppDbContext Db
@inject IReportService ReportService
@inject NavigationManager Navigation
@attribute [Authorize]

<PageTitle>Главная</PageTitle>

<div class="container-fluid">
    <h3 class="mb-4 fw-bold">Главная панель</h3>

    @if (isLoading)
    {
        <div class="text-center">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Загрузка...</span>
            </div>
        </div>
    }
    else if (!string.IsNullOrEmpty(loadError))
    {
        <div class="alert alert-danger">
            @loadError
            <button class="btn btn-link" @onclick="LoadData">Повторить</button>
        </div>
    }
    else
    {
        <!-- Верхний ряд: три карточки -->
        <div class="row mb-4">
            <!-- Последний отчёт (используем те же данные, что и на LastReport) -->
            <div class="col-md-4 mb-3">
                <div class="card border-0 shadow-sm h-100" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white;">
                    <div class="card-body d-flex flex-column justify-content-center">
                        <div class="d-flex align-items-center mb-3">
                            <i class="bi bi-file-earmark-text fs-1 me-3"></i>
                            <h5 class="card-title mb-0">Последний отчёт</h5>
                        </div>
                        @if (reportEntryCount > 0)
                        {
                            <h6 class="mb-2">Отчёт № 1</h6>
                            <p class="mb-1"><i class="bi bi-calendar3 me-2"></i>@(reportDate?.ToString("dd.MM.yyyy HH:mm") ?? "-")</p>
                            <p class="mb-0"><i class="bi bi-collection me-2"></i>Объектов: @reportEntryCount</p>
                        }
                        else
                        {
                            <p class="mb-0">Нет данных</p>
                        }
                    </div>
                </div>
            </div>

            <!-- Nodes -->
            <div class="col-md-4 mb-3">
                <div class="card border-0 shadow-sm h-100" style="background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%); color: white;">
                    <div class="card-body d-flex flex-column justify-content-center text-center">
                        <i class="bi bi-diagram-3 fs-1 mb-2"></i>
                        <h5 class="card-title">Nodes</h5>
                        <h2 class="display-4 fw-bold">@(stats?.TotalNodes ?? 0)</h2>
                        <p class="mb-0">в базе данных</p>
                    </div>
                </div>
            </div>

            <!-- Заявки -->
            <div class="col-md-4 mb-3">
                <div class="card border-0 shadow-sm h-100" style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%); color: white;">
                    <div class="card-body d-flex flex-column justify-content-center">
                        <h5 class="card-title"><i class="bi bi-ticket-perforated me-2"></i>Заявки</h5>
                        <ul class="list-unstyled mt-3 mb-0">
                            <li class="mb-2"><strong>Всего: @(stats?.TotalTickets ?? 0)</strong></li>
                            <li class="mb-2">Открытые: @(stats?.OpenTickets ?? 0)</li>
                            <li>Закрытые: @(stats?.ClosedTickets ?? 0)</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>

        <!-- Второй ряд: статусы заявок и топ-5 проблемных Node -->
        <div class="row">
            <!-- Статусы заявок (новая таблица) -->
            <div class="col-md-6 mb-4">
                <div class="card shadow-sm h-100">
                    <div class="card-header bg-white fw-bold">
                        <i class="bi bi-bar-chart-steps me-2"></i>Статусы заявок
                    </div>
                    <div class="card-body">
                        @if (_statusData.Any())
                        {
                            <table class="table table-borderless table-sm">
                                <tbody>
                                    @foreach (var kvp in _statusData)
                                    {
                                        <tr>
                                            <td><span class="badge @GetStatusBadgeClass(kvp.Key)">@GetStatusName(kvp.Key)</span></td>
                                            <td class="text-end fw-bold">@kvp.Value</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                        else
                        {
                            <p class="text-muted">Нет данных</p>
                        }
                    </div>
                </div>
            </div>

            <!-- Топ-5 проблемных Node -->
            <div class="col-md-6 mb-4">
                <div class="card shadow-sm h-100">
                    <div class="card-header bg-white fw-bold">
                        <i class="bi bi-exclamation-triangle-fill text-danger me-2"></i>Топ-5 проблемных Node
                    </div>
                    <div class="card-body">
                        @if (stats?.TopProblemNodes?.Any() == true)
                        {
                            <table class="table table-hover table-sm">
                                <thead class="table-light">
                                    <tr>
                                        <th>Node ID</th>
                                        <th>Количество заявок</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var node in stats.TopProblemNodes)
                                    {
                                        <tr style="cursor: pointer;" @onclick="() => NavigateToTickets(node.NodeId)">
                                            <td class="text-primary fw-bold">@node.NodeId</td>
                                            <td><span class="badge bg-danger">@node.TicketCount</span></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                        else
                        {
                            <p class="text-muted">Нет проблемных узлов.</p>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private DashboardStats? stats;
    private bool isLoading = true;
    private string? loadError;

    // Для последнего отчёта – количество узлов (как на LastReport)
    private int reportEntryCount;
    private DateTime? reportDate;

    // Статусы заявок (для таблицы)
    private Dictionary<string, int> _statusData = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        loadError = null;
        _statusData.Clear();
        try
        {
            // Основная статистика
            stats = new DashboardStats
            {
                TotalNodes = await Db.Nodes.CountAsync(),
                TotalTickets = await Db.Tickets.CountAsync(),
                OpenTickets = await Db.Tickets.CountAsync(t => t.TicketStatus == "0"),
                ClosedTickets = await Db.Tickets.CountAsync(t => t.TicketStatus == "1"),
                TopProblemNodes = await Db.Tickets
                    .GroupBy(t => t.NodeId)
                    .Select(g => new TopProblemNode
                    {
                        NodeId = g.Key ?? 0,
                        TicketCount = g.Count()
                    })
                    .OrderByDescending(x => x.TicketCount)
                    .Take(5)
                    .ToListAsync()
            };

            // Загружаем последнее состояние ВСЕХ узлов (точно как на LastReport)
            var allNodesState = await ReportService.GetLatestStateForAllNodesAsync();
            reportEntryCount = allNodesState.Count;      // 574
            reportDate = allNodesState.Any()
                ? allNodesState.Max(r => r.CreatedAtDateTime)
                : null;

            // Статусы заявок
            var statusCounts = await Db.Tickets
                .GroupBy(t => t.TicketStatus ?? "")
                .Select(g => new { Status = g.Key, Count = g.Count() })
                .ToListAsync();

            foreach (var item in statusCounts)
            {
                _statusData[item.Status] = item.Count;
            }

            isLoading = false;
        }
        catch (Exception ex)
        {
            loadError = $"Ошибка загрузки данных: {ex.Message}";
            isLoading = false;
        }
    }

    private static string GetStatusName(string status) => status switch
    {
        "0" => "Открыта",
        "1" => "Закрыта",
        "2" => "В ожидании",
        "3" => "В работе",
        "4" => "На паузе",
        "5" => "Отменена",
        _ => "Неизвестно"
    };

    private static string GetStatusBadgeClass(string status) => status switch
    {
        "0" => "bg-info",
        "1" => "bg-success",
        "2" => "bg-secondary",
        "3" => "bg-warning text-dark",
        "4" => "bg-dark",
        "5" => "bg-danger",
        _ => "bg-secondary"
    };

    private void NavigateToTickets(int nodeId)
    {
        Navigation.NavigateTo($"/tickets?search={nodeId}");
    }
}