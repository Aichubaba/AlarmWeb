@using BlazorApp2.Models
@using BlazorApp2.Helpers

<style>
    .modal-overlay {
        position: fixed;
        top: 0; left: 0; right: 0; bottom: 0;
        background: transparent;
        z-index: 99999;
        display: flex;
        align-items: center;
        justify-content: center;
        animation: fadeIn 0.2s ease;
    }
    .modal-content {
        border-radius: 1rem;
        box-shadow: 0 0.5rem 2rem rgba(0, 0, 0, 0.3);
        border: none;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        max-width: 95vw;
        width: auto;
    }
    .modal-custom-header,
    .modal-custom-footer {
        background: transparent;
        border: none;
    }
    .card-header {
        background-color: rgba(255,255,255,0.15);
        border-bottom: 1px solid rgba(255,255,255,0.2);
        color: #000000;
    }
    .card-body {
        background-color: white;
        color: #212529;
        border-radius: 0 0 0.5rem 0.5rem;
    }
    .btn-purple-outline {
        background-color: transparent;
        border: 2px solid white;
        color: white;
        border-radius: 2rem;
        padding: 0.5rem 2rem;
        font-weight: 600;
        transition: all 0.2s;
        margin-top: -6px;
    }
    .btn-purple-outline:hover {
        background-color: white;
        color: #6f42c1;
    }
    .error-block {
        border: 2px solid #ffc107;
        border-radius: 0.5rem;
        padding: 1rem;
        background-color: rgba(255,255,255,0.1);
        color: white;
        margin-bottom: 1rem;
    }
    .modal-title {
        font-size: 1.75rem;
        font-weight: 700;
    }
    .detail-row {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        margin-bottom: 0.4rem;
    }
    .detail-label {
        font-weight: 600;
        margin-right: 1rem;
        white-space: nowrap;
    }
    .detail-value {
        text-align: right;
        word-break: break-word;
    }
</style>

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public EventCallback<bool> IsVisibleChanged { get; set; }
    [Parameter] public Report? Report { get; set; }

    private async Task CloseModal() => await IsVisibleChanged.InvokeAsync(false);
    private string SafeDate(DateTime? date) => date?.ToString("dd.MM.yyyy HH:mm:ss") ?? "-";
}

@if (IsVisible && Report != null)
{
    <div class="modal-overlay" @onclick="CloseModal">
        <div class="modal-dialog modal-lg" style="pointer-events: auto;" @onclick:stopPropagation="true">
            <div class="modal-content" style="max-height: 90vh; overflow-y: auto;">
                <div class="modal-custom-header py-3 text-center">
                    <h5 class="modal-title">Детали</h5>
                </div>
                <div class="modal-body px-4 fs-6">
                    <div class="mb-3 text-center">
                        <span class="badge fs-6 @(Report.Available == true ? "bg-success" : "bg-danger")">
                            @(Report.Available == true ? "ДОСТУПЕН" : "НЕДОСТУПЕН")
                        </span>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="card mb-3 border-0 shadow-sm">
                                <div class="card-header fw-bold">Основная информация</div>
                                <div class="card-body">
                                    <div class="detail-row"><span class="detail-label">Название:</span><span class="detail-value">@Report.Title</span></div>
                                    <div class="detail-row"><span class="detail-label">Группа:</span><span class="detail-value">@Report.Group</span></div>
                                    <div class="detail-row"><span class="detail-label">ПВН:</span><span class="detail-value">@Report.PvnNumber</span></div>
                                    <div class="detail-row"><span class="detail-label">Node ID:</span><span class="detail-value">@Report.NodeId</span></div>
                                    <div class="detail-row"><span class="detail-label">Модель:</span><span class="detail-value">@Report.ModelName</span></div>
                                    <div class="detail-row"><span class="detail-label">Serial FD:</span><span class="detail-value">@Report.SerialFd</span></div>
                                </div>
                            </div>
                            <div class="card mb-3 border-0 shadow-sm">
                                <div class="card-header fw-bold">Состояние</div>
                                <div class="card-body">
                                    <div class="detail-row"><span class="detail-label">Температура:</span><span class="detail-value">@(Report.Temperature?.ToString() ?? "-") °C</span></div>
                                    <div class="detail-row">
                                        <span class="detail-label">Ошибки:</span>
                                        <span class="detail-value">
                                            <span class="badge @(Report.Errors == true ? "bg-warning" : "bg-success")">
                                                @(Report.Errors == true ? "ДА" : "НЕТ")
                                            </span>
                                        </span>
                                    </div>
                                    <div class="detail-row"><span class="detail-label">Очередь:</span><span class="detail-value">@(Report.QueueQuantity?.ToString() ?? "-")</span></div>
                                </div>
                            </div>
                            @if (Report.Errors == true)
                            {
                                <div class="error-block">
                                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                                    <strong>Описание ошибки:</strong> @Report.ErrorsDescription
                                </div>
                            }
                        </div>
                        <div class="col-md-6">
                            <div class="card mb-3 border-0 shadow-sm">
                                <div class="card-header fw-bold">Местоположение</div>
                                <div class="card-body">
                                    <div class="detail-row"><span class="detail-label">Локация:</span><span class="detail-value">@Report.Location</span></div>
                                    <div class="detail-row"><span class="detail-label">Широта:</span><span class="detail-value">@(Report.Latitude?.ToString("F6") ?? "-")</span></div>
                                    <div class="detail-row"><span class="detail-label">Долгота:</span><span class="detail-value">@(Report.Longitude?.ToString("F6") ?? "-")</span></div>
                                </div>
                            </div>
                            <div class="card mb-3 border-0 shadow-sm">
                                <div class="card-header fw-bold">Время работы</div>
                                <div class="card-body">
                                    <div class="detail-row"><span class="detail-label">Время работы:</span><span class="detail-value">@Report.UptimeHr</span></div>
                                    <div class="detail-row"><span class="detail-label">Время простоя:</span><span class="detail-value">@Report.DowntimeHr</span></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-custom-footer py-3 text-center">
                    <button class="btn btn-purple-outline" @onclick="CloseModal">
                        <i class="bi bi-x-circle me-1"></i> ЗАКРЫТЬ
                    </button>
                </div>
            </div>
        </div>
    </div>
}